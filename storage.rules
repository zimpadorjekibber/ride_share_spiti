rules_version = '2';

// ⚠️ PROTOTYPE / TESTING RULES — open access so photo upload works during testing.
// Before production, restrict (e.g. allow write: if request.auth != null and
// limit file size / content-type).
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read, write: if true;
    }
  }
}
