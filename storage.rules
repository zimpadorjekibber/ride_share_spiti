rules_version = '2';

// Spiti Setu — Storage rules: photos are public to view; only signed-in app
// clients may upload, and only reasonably-sized images (blocks abuse of the
// bucket as free file hosting).
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
