rules_version = '2';

// ⚠️ PROTOTYPE / TESTING RULES — open access so the app works during testing.
// Before going to production, lock these down (e.g. require request.auth != null
// and validate fields per collection).
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
